<?xml version="1.0" encoding="UTF-8"?>
<!-- Force UDP-only transport for user-session ROS 2 participants.
     Clearpath services run as 'administrator'; their Fast DDS shared-memory
     segments in /dev/shm are not writable by other users, so SHM data
     silently never crosses users. UDP works both ways. -->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <transport_descriptors>
    <transport_descriptor>
      <transport_id>udp_transport</transport_id>
      <type>UDPv4</type>
    </transport_descriptor>
  </transport_descriptors>
  <participant profile_name="udp_only" is_default_profile="true">
    <rtps>
      <userTransports>
        <transport_id>udp_transport</transport_id>
      </userTransports>
      <useBuiltinTransports>false</useBuiltinTransports>
    </rtps>
  </participant>
</profiles>
