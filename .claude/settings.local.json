{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__plugin_claude-mem_mcp-search__smart_outline",
      "Bash(python -c ' *)",
      "Read(//c/Users/minie/AppData/Local/Programs/Python//**)",
      "Read(//c/Users/minie/AppData/Local/Microsoft/WindowsApps/**)",
      "Bash(/c/Users/minie/AppData/Local/Microsoft/WindowsApps/python3 -c ' *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout -b *)",
      "Bash(git branch *)",
      "Bash(python -m py_compile *)",
      "Bash(python -m pytest *)",
      "Bash(python src/metriques.py)",
      "Bash(python src/validation_spatiale.py)",
      "PowerShell(py *)",
      "Bash(python -c \"import plotly; print\\('plotly', plotly.__version__\\)\")",
      "Bash(python -c \"import xgboost; print\\('xgboost ok'\\)\")",
      "Bash(python -c \"import pykrige; print\\('pykrige ok'\\)\")"
    ],
    "deny": [
      "Edit(./data/raw/**)",
      "Write(./data/raw/**)",
      "Edit(./notebooks_originals/**)",
      "Write(./notebooks_originals/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(pip install *)",
      "Bash(python -m pip install *)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File .claude/hooks/run_min_checks.ps1"
          }
        ]
      }
    ]
  },
  "preferredNotifChannel": "terminal_bell"
}
